{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Mecojoni",
  "scopeName": "source.mecojoni",
  "patterns": [
    { "include": "#front-matter" },
    { "include": "#comments" },
    { "include": "#rules" },
    { "include": "#productions" },
    { "include": "#raw-blocks" },
    { "include": "#strings" },
    { "include": "#clauses" },
    { "include": "#messages" },
    { "include": "#references" },
    { "include": "#values" },
    { "include": "#escapes" }
  ],
  "repository": {
    "front-matter": {
      "begin": "\\A---$",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.front-matter.mecojoni" }
      },
      "end": "^---$",
      "endCaptures": {
        "0": { "name": "punctuation.definition.front-matter.mecojoni" }
      },
      "name": "meta.front-matter.mecojoni",
      "patterns": [
        {
          "match": "^(\\s*)([A-Za-z][A-Za-z0-9_-]*)(:)",
          "captures": {
            "2": { "name": "entity.other.attribute-name.mecojoni" },
            "3": { "name": "punctuation.separator.key-value.mecojoni" }
          }
        },
        { "include": "#strings" },
        {
          "match": "\\b(?:true|false|weighted/1|diverse/1)\\b",
          "name": "constant.language.mecojoni"
        },
        {
          "match": "\\b\\d+(?:\\.\\d+)?\\b",
          "name": "constant.numeric.mecojoni"
        }
      ]
    },
    "comments": {
      "begin": "<!--",
      "end": "-->",
      "name": "comment.block.mecojoni"
    },
    "rules": {
      "match": "^(#)(\\s+)([A-Za-z][A-Za-z0-9_-]*(?:\\.[A-Za-z][A-Za-z0-9_-]*)?)",
      "captures": {
        "1": { "name": "punctuation.definition.heading.mecojoni" },
        "3": { "name": "entity.name.function.rule.mecojoni" }
      }
    },
    "productions": {
      "match": "^(\\s*)(-)(?:\\s+)(\\[(?:[^]\\n]|\\](?!\\s))*\\])?",
      "captures": {
        "2": { "name": "punctuation.definition.list.mecojoni" },
        "3": { "name": "meta.weight.mecojoni" }
      }
    },
    "raw-blocks": {
      "begin": "\\|raw(?:[+-])?\\s*$",
      "end": "^(?!\\s{2})",
      "name": "string.unquoted.raw.block.mecojoni"
    },
    "strings": {
      "patterns": [
        { "begin": "r\"", "end": "\"", "name": "string.quoted.raw.mecojoni" },
        {
          "begin": "\"",
          "end": "\"",
          "name": "string.quoted.double.mecojoni",
          "patterns": [{ "include": "#escapes" }]
        }
      ]
    },
    "clauses": {
      "begin": "\\{",
      "end": "\\}",
      "name": "meta.clause.mecojoni",
      "patterns": [
        {
          "match": "\\b(?:is|is not|and|or|not|as|true|false)\\b",
          "name": "keyword.operator.mecojoni"
        },
        { "include": "#references" },
        { "include": "#values" }
      ]
    },
    "messages": {
      "match": "&[A-Za-z][A-Za-z0-9_-]*",
      "name": "entity.name.function.message.mecojoni"
    },
    "references": {
      "match": "@(?:\\{)?[A-Za-z][A-Za-z0-9_-]*(?:\\.[A-Za-z][A-Za-z0-9_-]*)?",
      "name": "variable.function.rule-reference.mecojoni"
    },
    "values": {
      "match": "\\$[A-Za-z][A-Za-z0-9_-]*",
      "name": "variable.other.mecojoni"
    },
    "escapes": {
      "match": "\\\\(?:\\\\|\"|n|r|t|@|\\$|&|\\{|\\})",
      "name": "constant.character.escape.mecojoni"
    }
  }
}
